  <Button name="MailAttachment" virtual="true">
    <Size>
      <AbsDimension x="37" y="37" />
    </Size>
    <Layers>
      <Layer level="BACKGROUND">
        <Texture file="Interface\Buttons\UI-Slot-Background">
